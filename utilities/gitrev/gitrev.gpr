with "config/gitrev_config.gpr";
with "../utilities.gpr" ;

project Gitrev is

   for Source_Dirs use ("src/", "config/" , "..");
   for Object_Dir use "obj/" & Gitrev_Config.Build_Profile;
   for Exec_Dir use "../bin";
   for Main use ("gitrev.adb");

   package Compiler is
      for Default_Switches ("Ada") use Gitrev_Config.Ada_Compiler_Switches;
   end Compiler;

end Gitrev;
